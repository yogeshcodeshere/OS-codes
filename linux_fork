#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>

int main() {
    pid_t pid;

    pid = fork();

    if (pid < 0) {
        printf("fork fail\n");
        return 1;
    }

    if (pid == 0) {
        // Child process
        printf("Child process\n");
        printf("Child PID: %d\n", getpid());
        printf("Parent PID: %d\n", getppid());
    } 
    else {
        // Parent process
        printf("Parent process\n");
        printf("Parent PID: %d\n", getpid());
    }

    return 0;
}